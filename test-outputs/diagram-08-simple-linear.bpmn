        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_LeaveProcessed_di" bpmnElement="EndEvent_LeaveProcessed">
        <dc:Bounds x="548" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="524" y="221" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1yx1icz_di" bpmnElement="Flow_1yx1icz">
        <di:waypoint x="198" y="200" />
        <di:waypoint x="248" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_18zap61_di" bpmnElement="Flow_18zap61">
        <di:waypoint x="348" y="200" />
        <di:waypoint x="398" y="200" />
