<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_07jqbug">
    <bpmn:participant id="Participant_0ih3u5g" name="Hiring Process" processRef="Process_Hiring_Process" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Hiring_Process" name="Hiring Process" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_1galsv7">
      <bpmn:lane id="Lane_1n1m2ci" name="HR">
        <bpmn:flowNodeRef>UserTask_PostJobListing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ScheduleInterviews</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_OnboardEmployee</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Hired</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_11t3ijy" name="Hiring Manager">
        <bpmn:flowNodeRef>StartEvent_PositionOpened</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_DefineJobRequirements</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>UserTask_ConductInterview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Hire</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_NotHired</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_03kqbza" name="System">
        <bpmn:flowNodeRef>ServiceTask_SendOfferLetter</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_SendRejection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ServiceTask_ScreenResumes</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_0vgy3m3" sourceRef="UserTask_DefineJobRequirements" targetRef="UserTask_PostJobListing" />
    <bpmn:sequenceFlow id="Flow_0isd3qu" sourceRef="UserTask_PostJobListing" targetRef="ServiceTask_ScreenResumes" />
    <bpmn:sequenceFlow id="Flow_1ptfr5v" sourceRef="ServiceTask_ScreenResumes" targetRef="UserTask_ScheduleInterviews" />
    <bpmn:sequenceFlow id="Flow_1dgr42e" sourceRef="UserTask_ScheduleInterviews" targetRef="UserTask_ConductInterview" />
    <bpmn:sequenceFlow id="Flow_Hire" name="Hire" sourceRef="Gateway_Hire" targetRef="ServiceTask_SendOfferLetter">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${decision == 'hire'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Reject" name="Reject" sourceRef="Gateway_Hire" targetRef="ServiceTask_SendRejection" />
    <bpmn:sequenceFlow id="Flow_SendOfferLetter_to_OnboardEmployee" sourceRef="ServiceTask_SendOfferLetter" targetRef="UserTask_OnboardEmployee" />
    <bpmn:sequenceFlow id="Flow_SendRejection_to_NotHired" sourceRef="ServiceTask_SendRejection" targetRef="EndEvent_NotHired" />
    <bpmn:userTask id="UserTask_PostJobListing" name="Post Job Listing" camunda:candidateGroups="hr">
      <bpmn:incoming>Flow_0vgy3m3</bpmn:incoming>
      <bpmn:outgoing>Flow_0isd3qu</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_ScheduleInterviews" name="Schedule Interviews" camunda:candidateGroups="hr">
      <bpmn:incoming>Flow_1ptfr5v</bpmn:incoming>
      <bpmn:outgoing>Flow_1dgr42e</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_OnboardEmployee" name="Onboard Employee" camunda:candidateGroups="hr">
      <bpmn:incoming>Flow_SendOfferLetter_to_OnboardEmployee</bpmn:incoming>
      <bpmn:outgoing>Flow_OnboardEmployee_to_Hired</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Hired" name="Hired">
      <bpmn:incoming>Flow_OnboardEmployee_to_Hired</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_OnboardEmployee_to_Hired" sourceRef="UserTask_OnboardEmployee" targetRef="EndEvent_Hired" />
    <bpmn:startEvent id="StartEvent_PositionOpened" name="Position Opened">
      <bpmn:outgoing>Flow_13kt3yk</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_DefineJobRequirements" name="Define Job Requirements" camunda:candidateGroups="hiring-manager">
      <bpmn:incoming>Flow_13kt3yk</bpmn:incoming>
      <bpmn:outgoing>Flow_0vgy3m3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_ConductInterview" name="Conduct Interview" camunda:candidateGroups="hiring-manager">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="candidateName" label="Candidate Name" type="string">
            <camunda:validation>
              <camunda:constraint name="required" />
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="interviewScore" label="Interview Score (1-10)" type="long">
            <camunda:validation>
              <camunda:constraint name="min" config="1" />
              <camunda:constraint name="max" config="10" />
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="decision" label="Decision" type="enum">
            <camunda:value id="hire" name="Hire" />
            <camunda:value id="reject" name="Reject" />
            <camunda:value id="second-round" name="Second Round" />
          </camunda:formField>
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1dgr42e</bpmn:incoming>
      <bpmn:outgoing>Flow_1nu52v1</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Hire" name="Hire?" default="Flow_Reject">
      <bpmn:incoming>Flow_1nu52v1</bpmn:incoming>
      <bpmn:outgoing>Flow_Hire</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_NotHired" name="Not Hired">
      <bpmn:incoming>Flow_SendRejection_to_NotHired</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_13kt3yk" sourceRef="StartEvent_PositionOpened" targetRef="UserTask_DefineJobRequirements" />
    <bpmn:sequenceFlow id="Flow_1nu52v1" sourceRef="UserTask_ConductInterview" targetRef="Gateway_Hire" />
    <bpmn:serviceTask id="ServiceTask_SendOfferLetter" name="Send Offer Letter" camunda:type="external" camunda:topic="send-offer-letter">
      <bpmn:incoming>Flow_Hire</bpmn:incoming>
      <bpmn:outgoing>Flow_SendOfferLetter_to_OnboardEmployee</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_SendRejection" name="Send Rejection" camunda:type="external" camunda:topic="send-rejection">
      <bpmn:incoming>Flow_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRejection_to_NotHired</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_ScreenResumes" name="Screen Resumes" camunda:type="external" camunda:topic="screen-resumes">
      <bpmn:incoming>Flow_0isd3qu</bpmn:incoming>
      <bpmn:outgoing>Flow_1ptfr5v</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
