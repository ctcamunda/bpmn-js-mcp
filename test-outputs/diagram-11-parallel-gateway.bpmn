<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_Invoice_Processing" name="Invoice Processing" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="StartEvent_InvoiceReceived" name="Invoice Received">
      <bpmn:outgoing>Flow_1dg6ywd</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_LogInvoice" name="Log Invoice" camunda:candidateGroups="accounting">
      <bpmn:incoming>Flow_1dg6ywd</bpmn:incoming>
      <bpmn:outgoing>Flow_0p9x1rw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1dg6ywd" sourceRef="StartEvent_InvoiceReceived" targetRef="UserTask_LogInvoice" />
    <bpmn:parallelGateway id="Gateway_Fork" name="Fork">
      <bpmn:incoming>Flow_0p9x1rw</bpmn:incoming>
      <bpmn:outgoing>Flow_Fork_to_VerifyInvoice</bpmn:outgoing>
      <bpmn:outgoing>Flow_Fork_to_CheckDuplicate</bpmn:outgoing>
      <bpmn:outgoing>Flow_Fork_to_ValidateTaxID</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_0p9x1rw" sourceRef="UserTask_LogInvoice" targetRef="Gateway_Fork" />
    <bpmn:userTask id="UserTask_VerifyInvoice" name="Verify Invoice" camunda:candidateGroups="accounting">
      <bpmn:incoming>Flow_Fork_to_VerifyInvoice</bpmn:incoming>
      <bpmn:outgoing>Flow_VerifyInvoice_to_Join</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_CheckDuplicate" name="Check Duplicate" camunda:type="external" camunda:topic="check-duplicate">
      <bpmn:incoming>Flow_Fork_to_CheckDuplicate</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckDuplicate_to_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_ValidateTaxID" name="Validate Tax ID" camunda:type="external" camunda:topic="validate-tax-id">
      <bpmn:incoming>Flow_Fork_to_ValidateTaxID</bpmn:incoming>
      <bpmn:outgoing>Flow_ValidateTaxID_to_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="Gateway_Join" name="Join">
      <bpmn:incoming>Flow_VerifyInvoice_to_Join</bpmn:incoming>
      <bpmn:incoming>Flow_CheckDuplicate_to_Join</bpmn:incoming>
      <bpmn:incoming>Flow_ValidateTaxID_to_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Join_to_ApprovePayment</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="UserTask_ApprovePayment" name="Approve Payment" camunda:candidateGroups="finance-manager">
      <bpmn:incoming>Flow_Join_to_ApprovePayment</bpmn:incoming>
      <bpmn:outgoing>Flow_ApprovePayment_to_ExecutePayment</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_ExecutePayment" name="Execute Payment" camunda:type="external" camunda:topic="execute-payment">
      <bpmn:incoming>Flow_ApprovePayment_to_ExecutePayment</bpmn:incoming>
      <bpmn:outgoing>Flow_ExecutePayment_to_InvoicePaid</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_InvoicePaid" name="Invoice Paid">
      <bpmn:incoming>Flow_ExecutePayment_to_InvoicePaid</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Fork_to_VerifyInvoice" sourceRef="Gateway_Fork" targetRef="UserTask_VerifyInvoice" />
    <bpmn:sequenceFlow id="Flow_Fork_to_CheckDuplicate" sourceRef="Gateway_Fork" targetRef="ServiceTask_CheckDuplicate" />
    <bpmn:sequenceFlow id="Flow_Fork_to_ValidateTaxID" sourceRef="Gateway_Fork" targetRef="ServiceTask_ValidateTaxID" />
    <bpmn:sequenceFlow id="Flow_VerifyInvoice_to_Join" sourceRef="UserTask_VerifyInvoice" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_CheckDuplicate_to_Join" sourceRef="ServiceTask_CheckDuplicate" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_ValidateTaxID_to_Join" sourceRef="ServiceTask_ValidateTaxID" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_Join_to_ApprovePayment" sourceRef="Gateway_Join" targetRef="UserTask_ApprovePayment" />
    <bpmn:sequenceFlow id="Flow_ApprovePayment_to_ExecutePayment" sourceRef="UserTask_ApprovePayment" targetRef="ServiceTask_ExecutePayment" />
    <bpmn:sequenceFlow id="Flow_ExecutePayment_to_InvoicePaid" sourceRef="ServiceTask_ExecutePayment" targetRef="EndEvent_InvoicePaid" />
  </bpmn:process>
