        <bpmndi:BPMNLabel>
          <dc:Bounds x="1021" y="221" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1lcw4e5_di" bpmnElement="Flow_1lcw4e5">
        <di:waypoint x="198" y="200" />
        <di:waypoint x="248" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1e8hlwy_di" bpmnElement="Flow_1e8hlwy">
        <di:waypoint x="348" y="200" />
        <di:waypoint x="398" y="200" />
      </bpmndi:BPMNEdge>
