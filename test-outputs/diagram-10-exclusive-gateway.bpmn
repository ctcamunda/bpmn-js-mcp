        <di:waypoint x="498" y="200" />
        <di:waypoint x="548" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_032c619_di" bpmnElement="Flow_032c619">
        <di:waypoint x="848" y="200" />
        <di:waypoint x="898" y="200" />
      </bpmndi:BPMNEdge>
