<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_Service_Ticket_with_SLA" name="Service Ticket with SLA" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="StartEvent_TicketCreated" name="Ticket Created">
      <bpmn:outgoing>Flow_02orbps</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_AssessTicket" name="Assess Ticket" camunda:candidateGroups="support-l1">
      <bpmn:incoming>Flow_02orbps</bpmn:incoming>
      <bpmn:outgoing>Flow_0982b0g</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_02orbps" sourceRef="StartEvent_TicketCreated" targetRef="UserTask_AssessTicket" />
    <bpmn:serviceTask id="ServiceTask_AutoDiagnose" name="Auto-Diagnose" camunda:type="external" camunda:topic="auto-diagnose">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="resolved">${resolved}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0982b0g</bpmn:incoming>
      <bpmn:outgoing>Flow_0biwbkb</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0982b0g" sourceRef="UserTask_AssessTicket" targetRef="ServiceTask_AutoDiagnose" />
    <bpmn:exclusiveGateway id="Gateway_Resolved" name="Resolved?" default="Flow_No">
      <bpmn:incoming>Flow_0biwbkb</bpmn:incoming>
      <bpmn:outgoing>Flow_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0biwbkb" sourceRef="ServiceTask_AutoDiagnose" targetRef="Gateway_Resolved" />
    <bpmn:userTask id="UserTask_ManualFix" name="Manual Fix" camunda:candidateGroups="support-l2">
      <bpmn:incoming>Flow_No</bpmn:incoming>
      <bpmn:incoming>Flow_HandleDiagnosisFailure_to_ManualFix</bpmn:incoming>
      <bpmn:outgoing>Flow_ManualFix_to_SendResolution</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_SendResolution" name="Send Resolution" camunda:type="external" camunda:topic="send-resolution">
      <bpmn:incoming>Flow_Yes</bpmn:incoming>
      <bpmn:incoming>Flow_ManualFix_to_SendResolution</bpmn:incoming>
      <bpmn:outgoing>Flow_SendResolution_to_TicketClosed</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_TicketClosed" name="Ticket Closed">
      <bpmn:incoming>Flow_SendResolution_to_TicketClosed</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:boundaryEvent id="Event_SLATimer" name="SLA Timer" cancelActivity="false" attachedToRef="UserTask_AssessTicket">
      <bpmn:outgoing>Flow_SLATimer_to_EscalateToManager</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT2H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="UserTask_EscalateToManager" name="Escalate to Manager" camunda:candidateGroups="support-manager">
      <bpmn:incoming>Flow_SLATimer_to_EscalateToManager</bpmn:incoming>
      <bpmn:outgoing>Flow_EscalateToManager_to_Escalated</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Event_DiagnosisError" name="Diagnosis Error" attachedToRef="ServiceTask_AutoDiagnose">
      <bpmn:outgoing>Flow_DiagnosisError_to_HandleDiagnosisFailure</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_DiagnosisFailed" />
    </bpmn:boundaryEvent>
    <bpmn:userTask id="UserTask_HandleDiagnosisFailure" name="Handle Diagnosis Failure" camunda:candidateGroups="support-l2">
      <bpmn:incoming>Flow_DiagnosisError_to_HandleDiagnosisFailure</bpmn:incoming>
      <bpmn:outgoing>Flow_HandleDiagnosisFailure_to_ManualFix</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Escalated" name="Escalated">
      <bpmn:incoming>Flow_EscalateToManager_to_Escalated</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Yes" name="Yes" sourceRef="Gateway_Resolved" targetRef="ServiceTask_SendResolution">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${resolved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_No" name="No" sourceRef="Gateway_Resolved" targetRef="UserTask_ManualFix" />
    <bpmn:sequenceFlow id="Flow_ManualFix_to_SendResolution" sourceRef="UserTask_ManualFix" targetRef="ServiceTask_SendResolution" />
    <bpmn:sequenceFlow id="Flow_SendResolution_to_TicketClosed" sourceRef="ServiceTask_SendResolution" targetRef="EndEvent_TicketClosed" />
    <bpmn:sequenceFlow id="Flow_SLATimer_to_EscalateToManager" sourceRef="Event_SLATimer" targetRef="UserTask_EscalateToManager" />
    <bpmn:sequenceFlow id="Flow_EscalateToManager_to_Escalated" sourceRef="UserTask_EscalateToManager" targetRef="EndEvent_Escalated" />
    <bpmn:sequenceFlow id="Flow_DiagnosisError_to_HandleDiagnosisFailure" sourceRef="Event_DiagnosisError" targetRef="UserTask_HandleDiagnosisFailure" />
    <bpmn:sequenceFlow id="Flow_HandleDiagnosisFailure_to_ManualFix" sourceRef="UserTask_HandleDiagnosisFailure" targetRef="UserTask_ManualFix" />
  </bpmn:process>
  <bpmn:error id="Error_DiagnosisFailed" name="Diagnosis Failed" errorCode="DIAG_001" />
